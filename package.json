{
  "name": "recipes-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bash ./dev.sh",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:convex": "bun run --cwd apps/web dev:convex",
    "test:web": "bun run --cwd apps/web test",
    "test": "bun run --cwd apps/web test"
  }
}
